    "smooth_window": 5,
    "smooth_min_votes": 2,
    "min_blur_var": 0,
    "min_face_size": 40,
    "attendance_cooldown": 45,
    "device_fd": "AUTO:GPU,CPU",
    "device_lm": "AUTO:GPU,CPU",
    "device_reid": "AUTO:GPU,CPU",
    "no_event_snapshots": true
  },
  "models": {
    "face_detection": "models\\models\\face-detection-retail-0004\\FP32\\face-detection-retail-0004.xml",
    "landmarks": "models\\models\\landmarks-regression-retail-0009\\FP32\\landmarks-regression-retail-0009.xml",
    "reidentification": "models\\models\\face-reidentification-retail-0095\\FP32\\face-reidentification-retail-0095.xml"
  },
  "cameras": [
    {
      "name": "entry-1",
